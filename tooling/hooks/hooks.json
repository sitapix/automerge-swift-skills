{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/tooling/hooks/session-start-context.md\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/tooling/scripts/quality/lint_repo.py\" --root \"${CLAUDE_PLUGIN_ROOT}\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/tooling/hooks/detect-automerge-error.py\" \"${TOOL_OUTPUT}\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/tooling/hooks/detect-automerge-prompt.py\" \"${USER_PROMPT}\""
          }
        ]
      }
    ]
  }
}
